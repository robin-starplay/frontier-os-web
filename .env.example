# ─── Frontier OS Web — environment variables ──────────────────────────────────
#
# Copy this file to .env.local and fill in values for local development.
# In production (Vercel, Railway, Netlify, etc.) set these as environment variables.
#
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to the browser.

# ── Required ──────────────────────────────────────────────────────────────────

# Base URL of the backend API (without trailing slash).
# The URL analysis form POSTs to ${VITE_FRONTIER_API_BASE_URL}/api/analyse/url.
# When unset, the app shows "Backend API is not configured yet."
VITE_FRONTIER_API_BASE_URL=https://web-production-0224c.up.railway.app

# Clerk publishable key.
# Get this from https://dashboard.clerk.com → your application → API Keys.
# Must start with pk_test_ for development or pk_live_ for production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Clerk proxy URL (optional).
# If set, Clerk auth requests are routed through this proxy.
# Omit for standard Clerk usage; only needed for custom domain proxying.
# VITE_CLERK_PROXY_URL=
